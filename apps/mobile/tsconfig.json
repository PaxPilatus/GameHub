{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "./.tsdist",
    "tsBuildInfoFile": "./.tsdist/.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "references": [
    {
      "path": "../../packages/protocol"
    },
    {
      "path": "../../packages/sdk"
    }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "vite.config.ts"],
  "exclude": ["dist", ".tsdist"]
}
